# --- 数据库 ---
# Zeabur 绑定 Postgres 后自动注入；本地填 postgres://user:pass@host:5432/db
DATABASE_URL=
# 数据库要求 SSL 时取消注释
# PGSSL=require

# --- 加密密钥（必填）---
# AES 加密 Key 用。建议 openssl rand -hex 32 生成。部署后不要再改！
ENC_KEY=

# --- 管理员口令（必填）---
# 进入 /admin 后台的口令。建议用长随机串。
ADMIN_TOKEN=

# --- 库存阈值与通知（选填）---
# 剩余多少个时提醒（默认 10）
LOW_STOCK_THRESHOLD=10
# 管理员通知 webhook（Slack/Discord/飞书机器人地址）；不填则只在后台页面内提醒
NOTIFY_WEBHOOK_URL=
# webhook 类型：slack | discord | feishu | generic（默认 generic）
NOTIFY_TYPE=generic

# --- 端口（Zeabur 自动注入，本地默认 8080）---
# PORT=8080
