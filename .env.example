# --- 数据库 ---
DATABASE_URL=
# PGSSL=require

# --- 加密密钥（必填）---
# openssl rand -hex 32 生成。部署后不要再改！
ENC_KEY=

# --- 管理员口令 ---
# 不设则使用默认口令 071926z.ai。生产环境建议改成你自己的。
ADMIN_TOKEN=071926z.ai

# --- 每个 Key 最多发给多少个选手（默认 10，发满标记为已发送）---
MAX_PER_KEY=10

# --- 库存阈值与通知（选填）---
LOW_STOCK_THRESHOLD=10
NOTIFY_WEBHOOK_URL=
NOTIFY_TYPE=generic

# PORT=8080

# --- 多管理员（选填）---
# 多个管理员，逗号分隔，可写 "名字:口令"。设了它，登录用其中任一口令均可。
# 例：ADMIN_TOKENS="hazel:口令A,teammate:口令B"
ADMIN_TOKENS=

# --- 登录失败锁定（选填）---
LOGIN_MAX_FAILS=5
LOGIN_LOCK_MINUTES=15

# --- 报名白名单（B 方案）---
# true（默认）：只有导入名单的邮箱能领取；false：关闭白名单，任何邮箱都能领
WHITELIST_ENFORCED=true
